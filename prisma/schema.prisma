generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PACIENTE
  PROFESIONAL
  RECEPCIONISTA
  ADMINISTRADOR
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CHECKED_IN
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum TimeSlotStatus {
  AVAILABLE
  BOOKED
  BREAK
}

enum ProfessionalScheduleStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  CHANGES_REQUESTED
}

enum UnavailabilityType {
  VACATION
  SICK_LEAVE
  TRAINING
  ADMIN_TIME
  PERSONAL_LEAVE
  INTERNAL_BLOCK
  OTHER
}

enum UnavailabilityStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum InsuranceStatus {
  ACTIVE
  INACTIVE
  UNKNOWN
}

enum PrescriptionItemType {
  MEDICATION
  PROCEDURE
}

enum AllergySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AttachmentKind {
  XRAY
  LAB
  DOCUMENT
}

enum ClinicalNoteType {
  EVOLUTION
  OBSERVATION
  DIAGNOSIS
  PLAN
}

enum AccessLogAction {
  VIEW
  CREATE
  UPDATE
  DELETE
  EXPORT
}

enum ClinicDocumentTemplateType {
  CONSENT
  QUOTE
  PRESCRIPTION
}

enum LabOrderStatus {
  PENDING
  ORDERED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  WAIVED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

model Specialty {
  id                         String                @id @default(uuid())
  name                       String                @unique
  defaultSlotDurationMinutes Int
  active                     Boolean               @default(true)
  professionals              ProfessionalProfile[]
  services                   Service[]
}

model User {
  id                           String                           @id @default(uuid()) @db.Uuid
  email                        String                           @unique
  passwordHash                 String?
  emailVerified                DateTime?
  image                        String?
  role                         Role
  name                         String
  lastName                     String
  active                       Boolean                          @default(true)
  privacyMode                  Boolean                          @default(false)
  mfaEnabled                   Boolean                          @default(false)
  createdAt                    DateTime                         @default(now())
  passwordChangedAt            DateTime?
  mustChangePassword           Boolean                          @default(false)
  updatedAt                    DateTime                         @updatedAt
  professional                 ProfessionalProfile?
  patient                      PatientProfile?
  notifications                Notification[]
  notificationPreference       NotificationPreference?
  resetTokens                  PasswordResetToken[]
  clinicalNotesAuthored        ClinicalNote[]                   @relation("ClinicalNoteAuthor")
  clinicalNotesDeleted         ClinicalNote[]                   @relation("ClinicalNoteDeletedBy")
  clinicalAttachmentsUploaded  ClinicalAttachment[]             @relation("ClinicalAttachmentUploaded")
  clinicalAttachmentsDeleted   ClinicalAttachment[]             @relation("ClinicalAttachmentDeleted")
  prescriptionsDeleted         Prescription[]                   @relation("PrescriptionDeletedBy")
  consentsAccepted             SignedConsent[]                  @relation("SignedConsentAcceptedBy")
  clinicalEpisodesCreated      ClinicalEpisode[]                @relation("ClinicalEpisodesCreated")
  clinicalEpisodesUpdated      ClinicalEpisode[]                @relation("ClinicalEpisodesUpdated")
  clinicalEpisodesDeleted      ClinicalEpisode[]                @relation("ClinicalEpisodesDeleted")
  accessLogs                   AccessLog[]
  appointmentEvents            AppointmentEvent[]
  schedulesCreated             ProfessionalWorkingSchedule[]
  scheduleAdjustmentsRequested ProfessionalScheduleAdjustment[] @relation("ScheduleAdjustmentRequestedBy")
  scheduleAdjustmentsReviewed  ProfessionalScheduleAdjustment[] @relation("ScheduleAdjustmentReviewedBy")
  unavailabilityCreated        ProfessionalUnavailability[]     @relation("UnavailabilityCreatedBy")
  unavailabilityApproved       ProfessionalUnavailability[]     @relation("UnavailabilityApprovedBy")
  unavailabilityUpdated        ProfessionalUnavailability[]     @relation("UnavailabilityUpdatedBy")
  auditLogs                    AuditLog[]
  accounts                     Account[]
  sessions                     Session[]

  @@index([role])
  @@index([active])
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ProfessionalProfile {
  id                     String                           @id @default(uuid())
  userId                 String                           @unique @db.Uuid
  specialtyId            String
  slotDurationMinutes    Int?
  active                 Boolean                          @default(true)
  user                   User                             @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty              Specialty                        @relation(fields: [specialtyId], references: [id], onDelete: Restrict)
  timeSlots              TimeSlot[]
  appointments           Appointment[]
  availabilityRules      AvailabilityRule[]
  availabilityExceptions AvailabilityException[]
  availabilityBlocks     AvailabilityBlock[]
  professionalServices   ProfessionalService[]
  workingSchedules       ProfessionalWorkingSchedule[]
  scheduleAdjustments    ProfessionalScheduleAdjustment[]
  unavailabilityEntries  ProfessionalUnavailability[]
  clinicalEpisodes       ClinicalEpisode[]
  prescriptions          Prescription[]
}

model PatientProfile {
  id                  String               @id @default(uuid())
  userId              String               @unique @db.Uuid
  phone               String?
  documentId          String?
  dateOfBirth         DateTime?
  gender              String?
  insuranceProvider   String?
  insuranceStatus     InsuranceStatus?
  address             String?
  city                String?
  avatarUrl           String?
  patientCode         String?              @unique
  active              Boolean              @default(true)
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments        Appointment[]
  allergies           MedicalAllergy[]
  attachments         Attachment[]
  clinicalEpisodes    ClinicalEpisode[]
  clinicalAttachments ClinicalAttachment[]
  prescriptions       Prescription[]
  consents            SignedConsent[]
  accessLogs          AccessLog[]
}

model Service {
  id                   String                @id @default(uuid())
  name                 String                @unique
  description          String?
  priceCents           Int
  durationMinutes      Int?
  active               Boolean               @default(true)
  specialtyId          String?
  specialty            Specialty?            @relation(fields: [specialtyId], references: [id], onDelete: SetNull)
  appointments         Appointment[]
  professionalServices ProfessionalService[]

  @@index([active])
  @@index([specialtyId])
}

model TimeSlot {
  id             String              @id @default(uuid())
  professionalId String
  startAt        DateTime
  endAt          DateTime
  status         TimeSlotStatus      @default(AVAILABLE)
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  appointment    Appointment?

  @@unique([professionalId, startAt, endAt])
  @@index([professionalId])
  @@index([startAt])
}

model Appointment {
  id                String              @id @default(uuid())
  patientId         String
  professionalId    String
  timeSlotId        String              @unique
  serviceId         String
  serviceName       String?
  servicePriceCents Int?
  reason            String
  notes             String?
  status            AppointmentStatus   @default(SCHEDULED)
  paymentStatus     PaymentStatus       @default(PENDING)
  paymentMethod     PaymentMethod?
  paidAmountCents   Int?
  paidAt            DateTime?
  checkedInAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  reminderSentAt    DateTime?
  patient           PatientProfile      @relation(fields: [patientId], references: [id], onDelete: Restrict)
  professional      ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Restrict)
  timeSlot          TimeSlot            @relation(fields: [timeSlotId], references: [id], onDelete: Restrict)
  service           Service             @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  clinicalNotes     ClinicalNote[]
  prescription      Prescription?
  attachments       Attachment[]
  clinicalEpisodes  ClinicalEpisode[]
  events            AppointmentEvent[]

  @@index([patientId])
  @@index([professionalId])
  @@index([serviceId])
  @@index([status])
  @@index([createdAt])
}

model AppointmentEvent {
  id             String             @id @default(uuid())
  appointmentId  String
  actorUserId    String?            @db.Uuid
  actorRole      Role?
  action         String
  previousStatus AppointmentStatus?
  newStatus      AppointmentStatus?
  metadata       Json?
  createdAt      DateTime           @default(now())
  appointment    Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  actorUser      User?              @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([appointmentId, createdAt])
  @@index([actorUserId])
}

model ClinicalNote {
  id              String           @id @default(uuid())
  appointmentId   String?
  episodeId       String?
  authorUserId    String           @db.Uuid
  type            ClinicalNoteType @default(EVOLUTION)
  content         String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?          @db.Uuid
  appointment     Appointment?     @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  episode         ClinicalEpisode? @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  author          User             @relation("ClinicalNoteAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  deletedByUser   User?            @relation("ClinicalNoteDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  @@index([appointmentId])
  @@index([episodeId])
  @@index([authorUserId])
}

model Prescription {
  id              String               @id @default(uuid())
  appointmentId   String?              @unique
  episodeId       String?
  professionalId  String?
  patientId       String?
  content         Json?
  createdAt       DateTime             @default(now())
  issuedAt        DateTime?
  deletedAt       DateTime?
  deletedByUserId String?              @db.Uuid
  appointment     Appointment?         @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  episode         ClinicalEpisode?     @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  professional    ProfessionalProfile? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  patient         PatientProfile?      @relation(fields: [patientId], references: [id], onDelete: SetNull)
  deletedByUser   User?                @relation("PrescriptionDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  items           PrescriptionItem[]

  @@index([episodeId])
  @@index([professionalId])
}

model PrescriptionItem {
  id             String               @id @default(uuid())
  prescriptionId String
  type           PrescriptionItemType
  name           String
  dosage         String?
  frequency      String?
  instructions   String?
  createdAt      DateTime             @default(now())
  prescription   Prescription         @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
}

model MedicalAllergy {
  id        String          @id @default(uuid())
  patientId String
  substance String
  severity  AllergySeverity
  notes     String?
  createdAt DateTime        @default(now())
  patient   PatientProfile  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model Attachment {
  id            String          @id @default(uuid())
  appointmentId String?
  patientId     String?
  kind          AttachmentKind
  filename      String
  mimeType      String?
  size          Int?
  storageKey    String?
  url           String?
  dataUrl       String?
  createdAt     DateTime        @default(now())
  appointment   Appointment?    @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  patient       PatientProfile? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([appointmentId])
  @@index([patientId])
  @@index([kind])
}

model ClinicalEpisode {
  id               String               @id @default(uuid())
  patientId        String
  professionalId   String
  appointmentId    String?
  date             DateTime
  reason           String?
  notes            String?
  diagnosis        String?
  treatmentPlan    String?
  visibleToPatient Boolean              @default(false)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  createdByUserId  String               @db.Uuid
  updatedByUserId  String?              @db.Uuid
  deletedAt        DateTime?
  deletedByUserId  String?              @db.Uuid
  patient          PatientProfile       @relation(fields: [patientId], references: [id], onDelete: Restrict)
  professional     ProfessionalProfile  @relation(fields: [professionalId], references: [id], onDelete: Restrict)
  appointment      Appointment?         @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  createdByUser    User                 @relation("ClinicalEpisodesCreated", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUser    User?                @relation("ClinicalEpisodesUpdated", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser    User?                @relation("ClinicalEpisodesDeleted", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  notesEntries     ClinicalNote[]
  prescriptions    Prescription[]
  labOrders        LabOrder[]
  attachments      ClinicalAttachment[]

  @@index([patientId])
  @@index([professionalId])
  @@index([appointmentId])
  @@index([date])
  @@index([deletedAt])
}

model ClinicalAttachment {
  id               String          @id @default(uuid())
  episodeId        String
  patientId        String
  uploadedByUserId String          @db.Uuid
  filename         String
  mimeType         String
  size             Int
  storageKey       String
  data             Bytes? // DEPRECATED: now using external storage
  checksum         String?
  visibleToPatient Boolean         @default(false)
  createdAt        DateTime        @default(now())
  deletedAt        DateTime?
  deletedByUserId  String?         @db.Uuid
  episode          ClinicalEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  patient          PatientProfile  @relation(fields: [patientId], references: [id], onDelete: Restrict)
  uploadedByUser   User            @relation("ClinicalAttachmentUploaded", fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  deletedByUser    User?           @relation("ClinicalAttachmentDeleted", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  @@index([episodeId])
  @@index([patientId])
  @@index([deletedAt])
}

model AccessLog {
  id        String          @id @default(uuid())
  userId    String          @db.Uuid
  patientId String?
  action    AccessLogAction
  route     String
  requestId String
  metadata  Json?
  createdAt DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  patient   PatientProfile? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([patientId])
  @@index([action])
  @@index([createdAt])
}

model ClinicDocumentTemplate {
  id          String                     @id @default(uuid())
  type        ClinicDocumentTemplateType
  title       String
  contentHtml String
  active      Boolean                    @default(true)
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  consents    SignedConsent[]

  @@index([type])
  @@index([active])
}

model SignedConsent {
  id               String                 @id @default(uuid())
  patientId        String
  templateId       String
  acceptedAt       DateTime               @default(now())
  acceptedByUserId String                 @db.Uuid
  ipHash           String?
  userAgent        String?
  patient          PatientProfile         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  template         ClinicDocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  acceptedByUser   User                   @relation("SignedConsentAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([templateId])
}

model LabOrder {
  id        String          @id @default(uuid())
  episodeId String
  details   String
  status    LabOrderStatus  @default(PENDING)
  createdAt DateTime        @default(now())
  episode   ClinicalEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([episodeId])
}

model ProfessionalService {
  id                         String              @id @default(uuid())
  professionalId             String
  serviceId                  String
  active                     Boolean             @default(true)
  onlineBookable             Boolean             @default(true)
  appointmentDurationMinutes Int?
  bufferBeforeMinutes        Int?
  bufferAfterMinutes         Int?
  notes                      String?
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  professional               ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service                    Service             @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([professionalId, serviceId])
  @@index([serviceId, active])
  @@index([professionalId, active])
}

model ProfessionalWorkingSchedule {
  id              String                           @id @default(uuid())
  professionalId  String
  dayOfWeek       Int
  startTime       String
  endTime         String
  timezone        String                           @default("America/Bogota")
  effectiveFrom   DateTime?
  effectiveTo     DateTime?
  active          Boolean                          @default(true)
  status          ProfessionalScheduleStatus       @default(PENDING_CONFIRMATION)
  createdByUserId String?                          @db.Uuid
  notes           String?
  createdAt       DateTime                         @default(now())
  updatedAt       DateTime                         @updatedAt
  professional    ProfessionalProfile              @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  createdByUser   User?                            @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  adjustments     ProfessionalScheduleAdjustment[]

  @@unique([professionalId, dayOfWeek, startTime, endTime, timezone])
  @@index([professionalId, active])
  @@index([dayOfWeek, active])
}

model ProfessionalScheduleAdjustment {
  id                String                       @id @default(uuid())
  professionalId    String
  scheduleId        String?
  dayOfWeek         Int?
  startTime         String?
  endTime           String?
  effectiveFrom     DateTime
  effectiveTo       DateTime?
  timezone          String                       @default("America/Bogota")
  status            ProfessionalScheduleStatus   @default(CHANGES_REQUESTED)
  requestedByUserId String                       @db.Uuid
  reviewedByUserId  String?                      @db.Uuid
  note              String?
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt
  professional      ProfessionalProfile          @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  schedule          ProfessionalWorkingSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  requestedByUser   User                         @relation("ScheduleAdjustmentRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  reviewedByUser    User?                        @relation("ScheduleAdjustmentReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([professionalId, status])
  @@index([effectiveFrom])
}

model ProfessionalUnavailability {
  id               String               @id @default(uuid())
  professionalId   String
  type             UnavailabilityType
  status           UnavailabilityStatus @default(PENDING)
  startsAt         DateTime
  endsAt           DateTime
  fullDay          Boolean              @default(false)
  reason           String?
  notes            String?
  internalNotes    String?
  createdByUserId  String?              @db.Uuid
  approvedByUserId String?              @db.Uuid
  updatedByUserId  String?              @db.Uuid
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  professional     ProfessionalProfile  @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  createdByUser    User?                @relation("UnavailabilityCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedByUser   User?                @relation("UnavailabilityApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  updatedByUser    User?                @relation("UnavailabilityUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([professionalId, startsAt])
  @@index([type, status])
}

model AvailabilityRule {
  id             String              @id @default(uuid())
  professionalId String
  rrule          String
  startTime      String
  endTime        String
  timezone       String
  active         Boolean             @default(true)
  createdAt      DateTime            @default(now())
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId])
}

model AvailabilityException {
  id             String              @id @default(uuid())
  professionalId String
  date           DateTime
  isAvailable    Boolean             @default(false)
  startTime      String?
  endTime        String?
  reason         String?
  createdAt      DateTime            @default(now())
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId])
  @@index([date])
}

model AvailabilityBlock {
  id             String              @id @default(uuid())
  professionalId String
  startAt        DateTime
  endAt          DateTime
  reason         String?
  createdAt      DateTime            @default(now())
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, startAt, endAt])
  @@index([professionalId])
  @@index([startAt])
}

model ClinicHoliday {
  id        String   @id @default(uuid())
  date      DateTime @unique
  name      String
  createdAt DateTime @default(now())

  @@index([date])
}

model NotificationPreference {
  id           String   @id @default(uuid())
  userId       String   @unique @db.Uuid
  emailEnabled Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id         String    @id @default(uuid())
  userId     String    @db.Uuid
  type       String
  title      String
  body       String?
  entityType String?
  entityId   String?
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([readAt])
  @@index([createdAt])
}

model Campaign {
  id          String   @id @default(uuid())
  title       String
  description String?
  imageUrl    String
  ctaText     String?
  ctaUrl      String?
  startAt     DateTime
  endAt       DateTime
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([active])
  @@index([startAt])
  @@index([endAt])
}


model AuditLog {
  id              String   @id @default(uuid())
  actorUserId     String?  @db.Uuid
  actorIdentifier String?
  actorRole       String?
  action          String
  resourceType    String
  resourceId      String?
  targetLabel     String?
  status          String
  metadata        Json?
  createdAt       DateTime @default(now())
  actorUser       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([action])
  @@index([resourceType])
  @@index([status])
  @@index([createdAt])
}

model HomepageSettings {
  id                       String   @id @default("homepage-main")
  siteName                 String
  infoBarLocation          String
  infoBarPhone             String?
  infoBarHours             String?
  infoBarWhatsappHref      String?
  infoBarWhatsappLabel     String?
  infoBarEmailHref         String?
  infoBarEmailLabel        String?
  heroBadge                String?
  heroTitle                String
  heroDescription          String
  heroPrimaryButtonText    String?
  heroPrimaryButtonHref    String?
  heroSecondaryButtonText  String?
  heroSecondaryButtonHref  String?
  heroImageUrl             String?
  heroImageAlt             String?
  heroTestimonialQuote     String?
  heroTestimonialAuthor    String?
  heroTestimonialRole      String?
  heroTestimonialAvatarUrl String?
  heroHighlightTitle       String?
  heroHighlightDescription String?
  logoUrl                  String?
  servicesTitle            String
  servicesDescription      String
  specialistsBadge         String?
  specialistsTitle         String
  specialistsDescription   String
  bookingTitle             String
  bookingDescription       String
  bookingSelectLabel       String?
  bookingBenefitsTitle     String?
  bookingScheduleNote      String?
  bookingConsentNote       String?
  contactTitle             String
  contactDescription       String
  contactPhone             String?
  contactWhatsapp          String?
  contactEmail             String?
  contactAddress           String?
  contactHours             String?
  contactSupportTitle      String?
  contactLocationsTitle    String?
  contactBrand             String?
  contactMapEmbedUrl       String?
  floatingWhatsappNumber   String?
  floatingPhoneNumber      String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model HomepageService {
  id          String                     @id @default(uuid())
  title       String
  description String
  iconKey     String
  sortOrder   Int                        @default(0)
  isActive    Boolean                    @default(true)
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  highlights  HomepageServiceHighlight[]

  @@index([isActive, sortOrder])
}

model HomepageServiceHighlight {
  id                String          @id @default(uuid())
  homepageServiceId String
  text              String
  sortOrder         Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  service           HomepageService @relation(fields: [homepageServiceId], references: [id], onDelete: Cascade)

  @@index([homepageServiceId, sortOrder])
}

model HomepageSpecialist {
  id        String   @id @default(uuid())
  fullName  String
  specialty String
  bioShort  String
  imageUrl  String?
  altText   String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model HomepageHeroStat {
  id          String   @id @default(uuid())
  label       String
  description String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model HomepageBookingOption {
  id        String   @id @default(uuid())
  value     String   @unique
  label     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model HomepageBookingBenefit {
  id        String   @id @default(uuid())
  iconKey   String
  text      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model HomepageSocialLink {
  id        String   @id @default(uuid())
